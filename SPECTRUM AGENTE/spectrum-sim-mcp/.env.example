# Copia este archivo a .env y completa los valores.
# .env NUNCA debe commitearse (ya está en .gitignore).

# --- n8n ---
# Base URL del servidor n8n (sin slash final).
N8N_BASE_URL=https://agentsprod.redtec.ai
# Webhook del orquestador (Sof-IA).
N8N_WEBHOOK_URL=https://agentsprod.redtec.ai/webhook/spectrum-agent
# API key generada en n8n: Settings → API → Create API key.
N8N_API_KEY=

# --- MongoDB Atlas ---
# Connection string. Si es posible, usa un usuario con permisos read-only sobre
# `Centralizado` (la tool reset_user requiere write, pero la limitamos a docs cuyo
# manychat_id empiece con "test_").
MONGO_URI=
MONGO_DB=Centralizado

# --- Defaults para simulación ---
# page_id que se usará si la IA cliente no especifica uno. Debe existir en
# la colección manychat_settings para que CONTEXT 1 resuelva el proyecto.
DEFAULT_PAGE_ID=
# Timeout por request al webhook (segundos). El flujo tiene un Wait de 10s,
# y el procesamiento típico ronda 20s, así que 35 es el mínimo razonable.
WEBHOOK_TIMEOUT=35
