    {
      "parameters": {
        "jsCode": "const agentOutput = $input.first().json.output || '';\n\n let parsed;\n try {\n   // Intentar parsear si el agente devolvió JSON\n   const jsonMatch = agentOutput.match(/\\{[\\s\\S]*\\}/);\n   parsed = jsonMatch ? JSON.parse(jsonMatch[0]) : null;\n } catch(e) {\n   parsed = null;\n }\n\n return [{\n   json: {\n     response_text: parsed?.response || agentOutput,\n     escalate: parsed?.escalate || false,\n     categoria: parsed?.categoria || 'info',\n     raw_output: agentOutput\n   }\n }];"
      },
