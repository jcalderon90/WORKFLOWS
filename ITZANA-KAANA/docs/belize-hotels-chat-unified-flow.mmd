%% Belize Hotels Chat — Unified conversation flow
%% The shared flow across the group's properties; only the knowledge base
%% differs per property (Beach Villa / horseback ride shown as Itz'ana examples).
%% 
%% This shows the PHASE 1 conversation (guided links + knowledge base):
%%   - Returning guests are recognized by soft auth and greeted with NAME,
%%     YEAR of last visit, and ROOM TYPE only — nothing more is exposed.
%%   - There is no live availability read in Phase 1; dates are captured and
%%     used to pre-fill the iHotelier booking link.
%%   - Conversion = links: a content/room-page link while exploring, or an
%%     iHotelier booking link once intent is clear.
%% PHASE 2 evolution (annotated on the booking nodes): the iHotelier booking
%% link becomes NATIVE OPERA booking + payment via the gateway vendor, and
%% availability is read live from Opera at that step.
%% 
%% Lead capture runs throughout to the CRM, where the property's team follows
%% up. Three CRM fires: returning-matched (early), first-time qualified (mid),
%% and a final safety-net transcript; plus a dedicated high-priority fire for
%% Group 8+ / weddings.
%% 
%% Knowledge-base recall is shown at two natural moments (mid-discovery and
%% during activities), but the pattern is available at any guest input.
%% 
%% Paste into mermaid.live, the Miro Mermaid plugin, Notion, GitHub, or any
%% Mermaid-compatible renderer.

flowchart TD
    s1(["Guest opens chat"]):::start
    b_greet["Bot: greet +<br/>'First time with us,<br/>or have you stayed before?'"]:::bot
    g_first["Guest: first time / returning"]:::guest
    d_ret{"Returning?"}:::decision
    b_id["Bot: 'Welcome back —<br/>email or phone we have<br/>on file?' (soft auth)"]:::bot
    g_id["Guest: email / phone<br/>(or dodges)"]:::guest
    api_prof{{"API: Recognize returning guest<br/>(returns name, year of visit,<br/>room type — nothing more)"}}:::api
    d_match{"Matched?"}:::decision
    b_back["Bot: 'Welcome back, [first name] —<br/>you stayed in a Beach Villa last year.<br/>Lovely to have you with us again.'"]:::bot
    api_crm1{{"API: CRM #1<br/>returning guest engaged<br/>(early lead fire)"}}:::api
    b_dates["Bot: 'Roughly when<br/>are you thinking?'"]:::bot
    g_dates["Guest: dates / flexible"]:::guest
    b_party["Bot: 'How many of you?<br/>Adults only, or kids in the mix?'"]:::bot
    g_party["Guest: party + composition<br/>(may ask a question)"]:::guest
    d_kb1{"Question detected?<br/>(rooms, property, weather)"}:::decision
    api_kb1{{"API: Knowledge base<br/>rooms, property, weather, logistics"}}:::api
    b_ans1["Bot: answers,<br/>then continues the flow"]:::bot
    d_party{"Party type?"}:::decision
    b_pen["Bot: recommends<br/>Penthouse with plunge pool"]:::bot
    b_bv["Bot: recommends<br/>Beach Villa"]:::bot
    b_grp["Bot: 'Tell me about the occasion —<br/>event type? company, if applicable?<br/>best way to reach out to you?'"]:::bot
    g_grp["Guest: event type, company,<br/>preferred contact method"]:::guest
    act_grp_cap[/"Capture: full contact +<br/>event type + company"/]:::action
    ho_grp["Weddings / Groups specialist<br/>(1-business-day SLA)"]:::handoff
    api_crm_grp{{"API: CRM — HIGH PRIORITY<br/>group / wedding lead"}}:::api
    s_end_grp(["End:<br/>specialist follow-up<br/>within 1 business day"]):::start
    d_has_contact{"Already have<br/>contact?"}:::decision
    b_contact_ask["Bot: 'Phone or email, your call —<br/>in case we want to pick this up later.<br/>We only reach out about what you asked.'"]:::bot
    g_contact["Guest: phone / email<br/>(or dodges)"]:::guest
    d_provided{"Provided?"}:::decision
    act_cap_mid[/"Capture: phone OR email<br/>(customer's choice)"/]:::action
    api_crm2{{"API: CRM #2<br/>first-time qualified<br/>(mid lead fire)"}}:::api
    b_book["Bot: 'Want to see the room,<br/>book it, or talk to our team?'"]:::bot
    d_book{"Booking path"}:::decision
    act_content[/"Send room / content-page link<br/>(still exploring)"/]:::action
    act_deep[/"PRIMARY: Send iHotelier booking link<br/>(dates + room type pre-filled, UTM)<br/>— Phase 2: native Opera booking<br/>+ payment via gateway vendor"/]:::primary
    ho_res["Handoff:<br/>Reservations team"]:::handoff
    b_act["Bot: 'Now — want to look at<br/>activities while you're here?'"]:::bot
    g_act["Guest: yes / no / which?"]:::guest
    d_act{"Activities?"}:::decision
    b_actdisc["Bot: 'Water, land & culture,<br/>relax — or full itinerary?'"]:::bot
    g_actint["Guest: interest<br/>(e.g. 'How long is<br/>the horseback ride?')"]:::guest
    d_kb2{"Question detected?<br/>(activity details)"}:::decision
    api_kb2{{"API: Knowledge base<br/>activities: duration, price, includes"}}:::api
    b_ans2["Bot: answers,<br/>tees up recommendations"]:::bot
    b_actrec["Bot: activity recommendations<br/>(or itinerary draft)"]:::bot
    act_actlinks[/"PRIMARY: Send activity<br/>+ experience content links (UTM)<br/>— Phase 2: book in Opera"/]:::primary
    act_cap_final[/"Capture: any remaining<br/>fields (last name, phone, etc.)"/]:::action
    api_crm3{{"API: CRM #3<br/>final lead + full transcript<br/>(safety net — always fires)"}}:::api
    s_end(["End:<br/>qualified lead in CRM,<br/>concierge follow-up"]):::start

    s1 --> b_greet
    b_greet --> g_first
    g_first --> d_ret
    d_ret -->|Returning| b_id
    d_ret -->|First time| b_dates
    b_id --> g_id
    g_id --> api_prof
    api_prof --> d_match
    d_match -->|Match| b_back
    d_match -->|No match / dodged| b_dates
    b_back --> api_crm1
    api_crm1 --> b_dates
    b_dates --> g_dates
    g_dates --> b_party
    b_party --> g_party
    g_party --> d_kb1
    d_kb1 -->|Question| api_kb1
    d_kb1 -->|Info only| d_party
    api_kb1 --> b_ans1
    b_ans1 --> d_party
    d_party -->|2 adults, romantic| b_pen
    d_party -->|2 adults + kids| b_bv
    d_party -->|Group 8+| b_grp
    b_pen --> d_has_contact
    b_bv --> d_has_contact
    b_grp --> g_grp
    g_grp --> act_grp_cap
    act_grp_cap --> ho_grp
    ho_grp --> api_crm_grp
    api_crm_grp --> s_end_grp
    d_has_contact -->|Yes — skip ask| b_book
    d_has_contact -->|No| b_contact_ask
    b_contact_ask --> g_contact
    g_contact --> d_provided
    d_provided -->|Provided| act_cap_mid
    d_provided -->|Dodged — re-ask later| b_book
    act_cap_mid --> api_crm2
    api_crm2 --> b_book
    b_book --> d_book
    d_book -->|See the room| act_content
    d_book -->|Ready to book| act_deep
    d_book -->|Talk to team| ho_res
    act_content --> b_act
    act_deep --> b_act
    ho_res --> b_act
    b_act --> g_act
    g_act --> d_act
    d_act -->|No / later| act_cap_final
    d_act -->|Yes| b_actdisc
    b_actdisc --> g_actint
    g_actint --> d_kb2
    d_kb2 -->|Question| api_kb2
    d_kb2 -->|Interest only| b_actrec
    api_kb2 --> b_ans2
    b_ans2 --> b_actrec
    b_actrec --> act_actlinks
    act_actlinks --> act_cap_final
    act_cap_final --> api_crm3
    api_crm3 --> s_end

    classDef start fill:#0F0E3D,stroke:#0F0E3D,color:#FFFFFF
    classDef bot fill:#FFFFFF,stroke:#0F0E3D,color:#0F0E3D
    classDef guest fill:#F1EFF7,stroke:#9A9CA8,color:#0F0E3D
    classDef decision fill:#FFFFFF,stroke:#3DAEE2,color:#0F0E3D
    classDef api fill:#3DAEE2,stroke:#0F0E3D,color:#FFFFFF
    classDef action fill:#F1EFF7,stroke:#3DAEE2,color:#0F0E3D
    classDef handoff fill:#E66B5A,stroke:#E66B5A,color:#FFFFFF
    classDef primary fill:#B7DDF0,stroke:#3DAEE2,stroke-width:3px,color:#0F0E3D,font-weight:bold
